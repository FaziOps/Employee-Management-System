# Copy this file to .env and fill in real values. Never commit .env itself.

# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/ems_db"

# Server
PORT=5000
NODE_ENV=development

# CORS - the origin your Next.js frontend runs on
CLIENT_ORIGIN="http://localhost:3000"

# JWT
JWT_SECRET="replace-this-with-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="1d"
